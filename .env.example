# ============================================================
# OpenAI Manager 環境配置
# 複製此檔案為 .env 並填入你的配置
# ============================================================

# === 郵箱模式 ===
# auto  — 自動選擇（默認）
# gmail — Gmail +tag 別名模式
# tempmail — TempMail.lol 模式
EMAIL_MODE=auto

# === Gmail IMAP 模式 ===
# 需開啟兩步驟驗證 + 生成應用密碼
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# === Cloudflare Worker 模式 ===
OTP_WORKER_URL=https://email-otp-worker.your-subdomain.workers.dev
OTP_WORKER_TOKEN=your-api-token-here

# === Outlook 郵箱池 ===
# OAuth2 方式收取 OTP（在 tokens/outlook_pool.jsonl 中配置）
# 格式: {"email":"xxx@outlook.com","password":"xxx","ms_id":"client_id","ms_token":"refresh_token"}

# === 5sim.net SMS 接碼 ===
FIVESIM_API_KEY=your-5sim-api-key
FIVESIM_COUNTRY=usa
FIVESIM_OPERATOR=any

# === gzyi.top 帳號管理平台 ===
GZYI_API_URL=https://gzyi.top
GZYI_TOKEN=your-gzyi-admin-token

# === 通用設置 ===
TOKEN_OUTPUT_DIR=./tokens
OPENAI_SSL_VERIFY=1
SKIP_NET_CHECK=0
