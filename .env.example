# 郵箱域名 (你自己的域名，用於 Worker 模式)
MAIL_DOMAIN=yourdomain.com

# === 郵箱模式 ===
# auto  — 有 Gmail 配置就用 Gmail，否則 TempMail（默認）
# gmail — 強制 Gmail +tag 別名模式
# tempmail — 強制 TempMail.lol 模式
EMAIL_MODE=auto

# === Gmail IMAP 模式（推薦） ===
# 一個 Gmail 帳號 + 應用密碼，用 +tag 生成無限別名
# 需先開啟兩步驟驗證，再生成應用密碼:
# https://myaccount.google.com/apppasswords
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# === Cloudflare Worker 模式 ===
# 你的 Email OTP Worker URL
OTP_WORKER_URL=https://email-otp-worker.your-subdomain.workers.dev
# Worker API Token
OTP_WORKER_TOKEN=your-api-token-here

# === 5sim.net SMS 接碼 ===
FIVESIM_API_KEY=your-5sim-api-key
FIVESIM_COUNTRY=usa
FIVESIM_OPERATOR=any

# Token 輸出目錄
TOKEN_OUTPUT_DIR=./tokens

# SSL 驗證（0=關閉，1=開啟）
OPENAI_SSL_VERIFY=1

# 跳過網路檢查（0=不跳過，1=跳過）
SKIP_NET_CHECK=0
